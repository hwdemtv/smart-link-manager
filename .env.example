# ============================================
# Smart Link Manager 环境变量配置模板
# ============================================
# 复制此文件为 .env 并填写实际值
# 生产环境必须填写所有必需配置项

# ============================================
# 核心配置 (必需)
# ============================================

# 数据库连接字符串
# MySQL 格式: mysql://用户名:密码@主机:端口/数据库名
# SQLite 格式: sqlite://./database.db (仅开发测试)
DATABASE_URL=mysql://smart_link:your_password@localhost:3306/smart_link

# JWT 密钥 (必需，至少 32 位随机字符串)
# 生成方法: openssl rand -base64 32
JWT_SECRET=your-random-jwt-secret-at-least-32-characters

# 应用标识 (用于生成短链接)
# 生产环境设置为您的域名，如: https://s.yourdomain.com
VITE_APP_ID=http://localhost:3000

# ============================================
# 服务配置
# ============================================

# 运行环境: development | production | test
NODE_ENV=development

# 服务端口 (默认 3000)
PORT=3000

# 请求体大小限制 (默认 10mb)
BODY_LIMIT=10mb

# ============================================
# Redis 配置 (任务队列必需)
# ============================================

# Redis 主机地址
REDIS_HOST=localhost

# Redis 端口
REDIS_PORT=6379

# Redis 密码 (如未设置密码则留空或删除此行)
REDIS_PASSWORD=

# Redis 数据库编号 (默认 0)
REDIS_DB=0

# ============================================
# 管理员账户配置
# ============================================

# 默认管理员用户名
DEFAULT_ADMIN_USERNAME=admin

# 默认管理员密码
# 生产环境必须设置强密码
# 开发环境留空将自动生成随机密码并在启动日志中显示
DEFAULT_ADMIN_PASSWORD=

# ============================================
# 功能开关
# ============================================

# 禁用用户注册 (设为 true 禁止新用户注册)
REGISTRATION_DISABLED=false

# ============================================
# CORS 配置 (生产环境推荐)
# ============================================

# 允许的跨域来源，多个用逗号分隔
# 示例: https://yourdomain.com,https://app.yourdomain.com
CORS_ORIGINS=

# ============================================
# AI 服务配置 (可选)
# ============================================

# AI API 地址 (用于 SEO 智能生成)
BUILT_IN_FORGE_API_URL=

# AI API 密钥
BUILT_IN_FORGE_API_KEY=

# ============================================
# 授权服务配置 (可选)
# ============================================

# 授权服务器地址 (用于套餐验证)
LICENSE_SERVER_URL=

# ============================================
# MaxMind GeoIP 配置 (可选)
# ============================================

# MaxMind GeoIP 数据库路径
# 用于 IP 地理解析，获取访问者地理位置
# 下载: https://dev.maxmind.com/geoip/geolite2-free-geolocation-data
MAXMIND_DB_PATH=

# ============================================
# 测试配置 (仅开发环境)
# ============================================

# 启用集成测试
ENABLE_INTEGRATION_TESTS=false

# 测试数据库连接
TEST_DATABASE_URL=
